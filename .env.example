# MiQroForge 2.0 — 环境配置模板
# 使用方法：cp .env.example .env，然后按注释填写实际值
# .env 不入 git，每台机器独立配置

# ════════════════════════════════════════════════════
# WebUI 端口
# ════════════════════════════════════════════════════

# FastAPI 主端口（API + Argo 代理，对外暴露的唯一端口）
# 若 8100 已被占用，改为其他端口并同步修改 frontend/vite.config.ts 中的 proxy target
MF_API_PORT=8100

# Vite dev server 端口（仅 mf2 ui 无 --prod 时使用，VS Code 会自动转发）
MF_UI_PORT=5173

# ════════════════════════════════════════════════════
# Argo Workflow
# ════════════════════════════════════════════════════

# 工作流提交的 Kubernetes namespace
ARGO_NAMESPACE=miqroforge-v2

# Argo server 内网地址（服务端使用，用于 CLI 调用和 /argo/ 代理）
# 格式：https://<node-ip>:<nodeport>
# 查询命令：
#   node_ip:  kubectl get nodes -o jsonpath='{.items[0].status.addresses[?(@.type=="InternalIP")].address}'
#   nodeport: kubectl get svc argo-server -n argo -o jsonpath='{.spec.ports[0].nodePort}'
ARGO_SERVER_URL=https://<node-ip>:<nodeport>

# Argo UI 浏览器地址（返回给前端 TopBar 的链接）
# 默认保持 /argo/ — 通过 MiQroForge 内置代理访问，无需额外端口转发
# 若集群在本地或已有直连网络，可改为 https://<node-ip>:<nodeport>
ARGO_UI_URL=/argo/

# Argo API Token（若 Argo server 启用了认证则需要填写，否则留空）
# 获取方法：kubectl exec -n argo deploy/argo-server -- argo auth token
ARGO_TOKEN=

# Argo 工作流自动清理策略（秒）
# MF UI 启动时会同步到 Argo workflow-controller ConfigMap 的 workflowDefaults.ttlStrategy
ARGO_TTL_SUCCESS_SECONDS=2592000    # 成功任务保留 30 天
ARGO_TTL_FAILURE_SECONDS=5184000    # 失败任务保留 60 天

# ════════════════════════════════════════════════════
# Container Registry（节点镜像构建 & 推送，Phase 1）
# ════════════════════════════════════════════════════

# 镜像仓库地址（Harbor / Docker Hub / GitLab Registry 等）
REGISTRY_URL=registry.example.com
REGISTRY_PROJECT=miqroforge

# 集群拉取镜像时使用的仓库前缀（写入编译后的 Argo YAML）
# 本地 Docker Hub 可访问时留空；私有仓库填写完整前缀
# 示例：harbor.example.local/miqroforge
IMAGE_REGISTRY=

# ════════════════════════════════════════════════════
# Docker Hub 国内镜像加速（可选）
# ════════════════════════════════════════════════════

# 集群无法直连 Docker Hub 时，配置国内加速站
# 编译器生成的 lightweight 节点镜像地址会自动替换为 <MIRROR>/library/<image>:<tag>
# 私有仓库（registry.yaml 中有对应条目）优先级高于此设置
#
# 常用镜像站（任选其一）：
#   docker.m.daocloud.io         — DaoCloud（稳定，推荐）
#   docker.mirrors.ustc.edu.cn   — 中科大（学术网友好）
#   mirror.baidubce.com          — 百度云
#
# 生效后效果示例：python:3.10-slim → docker.m.daocloud.io/library/python:3.10-slim
DOCKER_HUB_MIRROR=

# ════════════════════════════════════════════════════
# LLM（Phase 2）
# ════════════════════════════════════════════════════
#
# LLM 配置已迁移至 userdata/models.yaml（模型注册表）。
# .env 中不再需要任何 LLM 相关变量。
#
# 快速开始：
#   cp models.yaml.example userdata/models.yaml
#   编辑 userdata/models.yaml，填入 proxy.api_key
#
# 支持：任意 OpenAI 兼容接口（官方 / 第三方分发站 / 本地 Ollama）
# 文档：models.yaml.example
