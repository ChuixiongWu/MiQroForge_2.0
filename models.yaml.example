# MiQroForge 2.0 — 模型注册表模板
#
# 使用方法：
#   cp models.yaml.example userdata/models.yaml
#   编辑 userdata/models.yaml，填入真实的 API key
#
# userdata/ 目录已在 .gitignore 中，API key 不会提交到 git。
# ─────────────────────────────────────────────────────────────────────────────

# ─── Provider 注册表（API 连接配置）───────────────────────────────────────────
#
# 每个 provider 定义了一个 API 入口。type 字段决定使用哪个 LangChain 类：
#   anthropic  → langchain_anthropic.ChatAnthropic
#   openai     → langchain_openai.ChatOpenAI
#   google     → langchain_google_genai.ChatGoogleGenerativeAI
#
# 模型可通过 base_url / api_key 覆盖 provider 的默认值。
#
providers:
  anthropic:
    type: anthropic
    base_url: https://api.anthropic.com
    api_key: sk-ant-YOUR_KEY_HERE

  deepseek:
    type: openai                # DeepSeek 使用 OpenAI 兼容协议
    base_url: https://api.deepseek.com/v1
    api_key: sk-YOUR_KEY_HERE

  openai-proxy:
    type: openai
    base_url: https://api.openai-proxy.org/v1
    api_key: sk-YOUR_KEY_HERE

# ─── 模型注册表 ──────────────────────────────────────────────────────────────
#
# 每个条目：
#   model_id:     API 实际接受的 model 名称（必填）
#   provider:     引用上面 providers 中的名称（必填）
#   base_url:     覆盖 provider.base_url（可选，用于模型级代理切换）
#   api_key:      覆盖 provider.api_key（可选）
#   extra_params: 额外参数，透传到 LLM 构造器（可选）
#                 - openai provider  → ChatOpenAI(extra_body={...})，绕过 SDK 校验
#                 - anthropic provider → ChatAnthropic(**{...})
#
models:
  opus:
    model_id: claude-opus-4-7
    provider: anthropic

  sonnet:
    model_id: claude-sonnet-4-6
    provider: anthropic

  gemini:
    model_id: gemini-3.1-pro-preview
    provider: openai-proxy

  glm:
    model_id: glm-5.1
    provider: openai-proxy

  deepseek:
    model_id: deepseek-v4-pro
    provider: deepseek
    # DeepSeek v4-pro thinking 模式（思考链可见）
    extra_params:
      thinking: true

  flash:
    model_id: deepseek-v4-flash
    provider: deepseek

  # 本地 Ollama 示例
  # local-qwen:
  #   model_id: qwen2.5:32b
  #   provider: ollama-local

# 默认模型（agents 未单独指定时使用）
default_model: deepseek

# ─── Agent → 模型 映射 ────────────────────────────────────────────────────────
#
# purpose 名称对应代码中 LLMConfig.get_chat_model(purpose="...") 的调用。
#
agents:
  planner: opus               # 语义工作流规划（推理能力优先）
  evaluator: glm              # 评判器（速度/成本优先）
  evaluator_vision: opus      # 视觉评判器（多模态，需强视觉模型）
  yaml_coder: glm             # MF YAML 生成（代码质量优先）
  node_generator: opus        # 节点生成（代码 + 推理）
  node_explorer: flash        # 探索子 Agent（速度优先，上下文隔离后用快速模型）
